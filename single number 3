class Solution {
public:
    vector<int> singleNumber(vector<int>& nums) {
        long ans=0;
        for(auto it: nums){
            ans^=it;
        }
        int rightset=(ans & (ans-1)) ^ ans;
        int a=0,b=0;
        for(int i=0;i<nums.size();i++){
            if( nums[i] & rightset)
            a^=nums[i];
            else
            b^=nums[i];
        }
        return {a,b};
    }
};
