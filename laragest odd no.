class Solution {
public:
    string largestOddNumber(string num) {
        int n=num.size();
        int i,idx=-1;
        for(i=n-1;i>=0;i--){
            if((num[i] - '0') % 2 != 0){
            idx=i;
            break;}
        }
        i=0;
        while(i<=idx && num[i]=='0') i++;
        return num.substr(i,idx-i+1);
    }
};
