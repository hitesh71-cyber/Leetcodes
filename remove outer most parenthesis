class Solution {
public:
    string removeOuterParentheses(string s) {
        string result;
        int n=s.size();
        int c=0;
        for(int i=0;i<n;i++){
            if(s[i]=='('){
                if(c>0) 
                result+=s[i];
                c++;
            }
            else if(s[i]==')'){
                c--;
                if(c>0)
                result+=s[i];
            }
         }
         return result;
    }
};
